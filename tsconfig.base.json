{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@cogent/shared-types": [
        "./packages/shared-types/src"
      ],
      "@cogent/agent-core": [
        "./packages/agent-core/src"
      ]
    }
  }
}
